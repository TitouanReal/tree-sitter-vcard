{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "vcard",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "property"
          },
          {
            "type": "REPEAT1",
            "content": {
              "type": "SYMBOL",
              "name": "crlf"
            }
          }
        ]
      }
    },
    "crlf": {
      "type": "STRING",
      "value": "\r\n"
    },
    "property": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "property_name"
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "SYMBOL",
          "name": "property_value"
        }
      ]
    },
    "property_name": {
      "type": "PATTERN",
      "value": "[A-Za-z0-9-(\\r\\n\\x20)(\\r\\n\\t)]+"
    },
    "property_value": {
      "type": "PATTERN",
      "value": "[A-Za-z0-9-]*"
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}